<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BUDGET TRACKER PRO</title>

  <link rel="manifest" href="manifest.json">
  <meta name="theme-color" content="#6366f1">

  <style>
    :root {
      --primary: #6366f1;
      --income: #10b981;
      --expense: #f43f5e;
      --bg: #f8fafc;
      --card: #ffffff;
      --text: #1e293b;
      --text-muted: #64748b;
    }

    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: linear-gradient(135deg, #e0e7ff 0%, #f1f5f9 100%);
      color: var(--text);
      margin: 0;
      display: flex;
      justify-content: center;
      min-height: 100vh;
      padding: 20px;
    }

    .container {
      background: var(--card);
      width: 100%;
      max-width: 600px;
      padding: 28px;
      border-radius: 28px;
      box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
    }

    h2 {
      font-size: 1.8rem;
      font-weight: 900;
      text-align: center;
      margin-bottom: 24px;
      color: var(--primary);
      letter-spacing: 2px;
    }

    h3 {
      font-size: 0.8rem;
      margin-bottom: 12px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      border-bottom: 2px solid #f1f5f9;
      padding-bottom: 5px;
    }

    .balance {
      text-align: center;
      background: linear-gradient(135deg, var(--primary), #8b5cf6);
      padding: 20px;
      border-radius: 20px;
      margin-bottom: 16px;
      color: white;
    }

    .balance small { text-transform: uppercase; font-size: 0.7rem; opacity: 0.8; }
    .balance span { display: block; font-size: 2rem; font-weight: 700; }

    .summary { 
      display: flex; 
      gap: 10px; 
      margin-bottom: 24px; 
    }

    .box {
      background: #ffffff;
      padding: 12px;
      border-radius: 16px;
      border: 1px solid #f1f5f9;
      flex: 1;
      text-align: center;
    }

    .box small { color: var(--text-muted); font-size: 0.65rem; font-weight: 700; text-transform: uppercase; display: block; }
    .box span { font-size: 1rem; font-weight: 700; }
    
    .income-text { color: var(--income); }
    .expense-text { color: var(--expense); }

    .input-row {
      display: flex;
      gap: 8px;
      margin-bottom: 8px;
    }

    #text { flex: 2; }
    #amount { flex: 1; }

    .form input, .form select {
      padding: 12px;
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      box-sizing: border-box;
      font-size: 0.9rem;
    }

    .form select { width: 100%; margin-bottom: 8px; text-transform: uppercase; font-weight: 600; }

    input::-webkit-outer-spin-button, input::-webkit-inner-spin-button {
      -webkit-appearance: none;
    }

    button {
      width: 100%;
      padding: 14px;
      background: var(--primary);
      border: none;
      border-radius: 12px;
      color: white;
      font-weight: 800;
      cursor: pointer;
      text-transform: uppercase;
    }

    .history-container {
      display: flex;
      gap: 20px;
      margin-top: 24px;
    }

    .history-column {
      flex: 1;
      min-width: 0;
    }

    ul { 
      list-style: none; 
      padding: 0; 
      margin: 0; 
      max-height: 250px; 
      overflow-y: auto; 
    }

    .transaction {
      background: #f8fafc;
      padding: 10px;
      margin-bottom: 8px;
      border-radius: 10px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border: 1px solid #f1f5f9;
    }

    .trans-info b { display: block; font-size: 0.9rem; }
    .trans-info small { color: var(--text-muted); font-size: 0.75rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block; max-width: 80px; }

    .delete {
      color: #cbd5e1;
      cursor: pointer;
      font-size: 1rem;
    }

    .empty-msg {
      text-align: center;
      font-size: 0.75rem;
      color: var(--text-muted);
      padding: 10px;
    }

    .btn-clear {
      background: none;
      color: #94a3b8;
      font-size: 0.7rem;
      text-decoration: underline;
      margin-top: 20px;
      cursor: pointer;
      border: none;
      width: 100%;
      text-transform: uppercase;
    }
  </style>
</head>

<body>
  <div class="container">
    <h2>BUDGET TRACKER</h2>

    <div class="balance">
      <small>TOTAL BALANCE</small>
      <span>₱<span id="balance">0</span></span>
    </div>

    <div class="summary">
      <div class="box">
        <small>INCOME</small>
        <span class="income-text">₱<span id="income">0</span></span>
      </div>
      <div class="box">
        <small>EXPENSE</small>
        <span class="expense-text">₱<span id="expense">0</span></span>
      </div>
    </div>

    <div class="form">
      <div class="input-row">
        <input id="text" placeholder="Description">
        <input id="amount" type="number" placeholder="Amount">
      </div>
      <select id="type">
        <option value="expense">EXPENSE</option>
        <option value="income">INCOME</option>
      </select>
      <button onclick="addTransaction()">ADD TRANSACTION</button>
    </div>

    <div class="history-container">
      <div class="history-column">
        <h3>INCOME HISTORY</h3>
        <ul id="income-list"></ul>
      </div>
      <div class="history-column">
        <h3>EXPENSE HISTORY</h3>
        <ul id="expense-list"></ul>
      </div>
    </div>

    <button class="btn-clear" onclick="clearAll()">RESET ALL DATA</button>
  </div>

  <script>
    let transactions = JSON.parse(localStorage.getItem("transactions")) || [];

    function save() { 
      localStorage.setItem("transactions", JSON.stringify(transactions)); 
    }

    function addTransaction() {
      const text = document.getElementById("text").value;
      const amount = document.getElementById("amount").value;
      const type = document.getElementById("type").value;

      if (!text || !amount || Number(amount) <= 0) {
        return alert("PLEASE FILL IN ALL DETAILS.");
      }

      const transaction = {
        id: Date.now(),
        text,
        amount: Number(amount),
        type,
        date: new Date().toLocaleDateString()
      };

      transactions.push(transaction);
      document.getElementById("text").value = "";
      document.getElementById("amount").value = "";
      
      save();
      updateUI();
    }

    function updateUI() {
      const incomeList = document.getElementById("income-list");
      const expenseList = document.getElementById("expense-list");
      
      incomeList.innerHTML = "";
      expenseList.innerHTML = "";
      
      let totalIncome = 0;
      let totalExpense = 0;

      transactions.forEach(t => {
        const li = document.createElement("li");
        li.className = "transaction";
        li.innerHTML = `
          <div class="trans-info">
            <b>₱${t.amount.toLocaleString()}</b>
            <small title="${t.text}">${t.text}</small>
          </div>
          <div class="delete" onclick="deleteTransaction(${t.id})">&times;</div>
        `;

        if (t.type === "income") {
          totalIncome += t.amount;
          incomeList.appendChild(li);
        } else {
          totalExpense += t.amount;
          expenseList.appendChild(li);
        }
      });

      if (incomeList.innerHTML === "") incomeList.innerHTML = '<div class="empty-msg">NONE</div>';
      if (expenseList.innerHTML === "") expenseList.innerHTML = '<div class="empty-msg">NONE</div>';

      document.getElementById("income").innerText = totalIncome.toLocaleString();
      document.getElementById("expense").innerText = totalExpense.toLocaleString();
      document.getElementById("balance").innerText = (totalIncome - totalExpense).toLocaleString();
    }

    function deleteTransaction(id) {
      transactions = transactions.filter(t => t.id !== id);
      save();
      updateUI();
    }

    function clearAll() {
      if(confirm("WIPE ALL RECORDS?")) {
        transactions = [];
        save();
        updateUI();
      }
    }

    updateUI();
  </script>
</body>
</html>
